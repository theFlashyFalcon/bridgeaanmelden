# ── Club-instellingen ────────────────────────────────────────────────────────
# Naam van de bridgeclub, zoals weergegeven in de app en e-mails.
CLUB_NAAM=MijnBridgeClub

# Pad naar de NBB-Rekenprogramma ledenlijst (CSV-export). Leden hierin kunnen
# direct een account aanmaken; anderen worden beoordeeld door een beheerder.
# Laat leeg of verwijder om de automatische import over te slaan.
CLUB_LEDENLIJST_CSV=data/ledenlijst_mijnclub.csv

# Gedeeld geheim voor automatisch inloggen via club-wissel.
# Stel DEZELFDE waarde in bij alle clubs die samen één netwerk vormen.
# Laat leeg om de wissel-knop te verbergen.
INTER_CLUB_SECRET=verander-dit-naar-een-lang-willekeurig-geheim

# Andere clubs waartussen gebruikers kunnen wisselen.
# Formaat: Naam|URL; gescheiden door puntkomma's.
# Voorbeeld: ANDERE_CLUBS=Club X|https://clubx.nl;Club Y|https://cluby.nl
ANDERE_CLUBS=

# ── Technische instellingen ───────────────────────────────────────────────────
# Session signing key — change this to a long random string in production
SECRET_KEY=change-me-to-a-long-random-secret

# E-mailadres van de eerste beheerder. Krijgt automatisch admin-rol bij opstarten.
ADMIN_EMAIL=marieke@summadigita.com

# Database URL (defaults to local SQLite if not set)
# DATABASE_URL=sqlite:///./bridgeclub.db
# DATABASE_URL=postgresql://user:password@localhost/bridgeclub

# Public base URL of the app (used in invitation emails).
# Set this to the exact URL users access the app with, e.g. https://jouwapp.nl
# Without this, the URL is derived from the incoming request which may be wrong behind a proxy.
BASE_URL=https://jouwapp.nl

# SMTP settings for sending emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com
