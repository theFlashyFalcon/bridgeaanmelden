# Google OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Session signing key — change this to a long random string in production
SECRET_KEY=change-me-to-a-long-random-secret

# Database URL (defaults to local SQLite if not set)
# DATABASE_URL=sqlite:///./bridgeclub.db
# DATABASE_URL=postgresql://user:password@localhost/bridgeclub
